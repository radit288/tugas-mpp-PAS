ingkungan )\n- Great Air Flow System\n\n————————\n\nSIZE CHART :\n- 37 : 24 CM\n- 38 : 24,5 CM\n- 39 : 25,5 CM\n- 40 : 26 CM\n","__typename":"pdpDataProductDetailDescription"},"$ROOT_QUERY.pdpMainInfo({\"extraPayload\":\"\",\"layoutID\":\"\",\"productKey\":\"kanky-story-gozen-sepatu-sneakers-casual-sport-sekolah-wanita-dewasa-1729848468575324457\",\"queryParam\":\"\",\"shopDomain\":\"sepatukanky\",\"source\":\"P1\",\"userLocation\":{\"addressID\":\"\",\"cityID\":\"176\",\"districtID\":\"2274\",\"latlon\":\"\",\"postalCode\":\"\"}}).components.5.data.0.content.0":{"title":"Kondisi","subtitle":"Baru","applink":"","showAtFront":true,"isAnnotation":false,"__typename":"pdpContentProductDetail"},"$ROOT_QUERY.pdpMainInfo({\"extraPayload\":\"\",\"layoutID\":\"\",\"productKey\":\"kanky-story-gozen-sepatu-sneakers-casual-sport-sekolah-wanita-dewasa-1729848468575324457\",\"queryParam\":\"\",\"shopDomain\":\"sepatukanky\",\"source\":\"P1\",\"userLocation\":{\"addressID\":\"\",\"cityID\":\"176\",\"districtID\":\"2274\",\"latlon\":\"\",\"postalCode\":\"\"}}).components.5.data.0.content.1":{"title":"Pemesanan Minimum","subtitle":"1 Buah","applink":"","showAtFront":true,"isAnnotation":false,"__typename":"pdpContentProductDetail"},"$ROOT_QUERY.pdpMainInfo({\"extraPayload\":\"\",\"layoutID\":\"\",\"productKey\":\"kanky-story-gozen-sepatu-sneakers-casual-sport-sekolah-wanita-dewasa-1729848468575324457\",\"queryParam\":\"\",\"shopDomain\":\"sepatukanky\",\"source\":\"P1\",\"userLocation\":{\"addressID\":\"\",\"cityID\":\"176\",\"districtID\":\"2274\",\"latlon\":\"\",\"postalCode\":\"\"}}).components.5.data.0.content.2":{"title":"Kategori","subtitle":"Sneakers Wanita","applink":"https://www.tokopedia.com/p/fashion-wanita/sepatu-wanita/sneakers-wanita","showAtFront":false,"isAnnotation":false,"__typename":"pdpContentProductDetail"},"$ROOT_QUERY.pdpMainInfo({\"extraPayload\":\"\",\"layoutID\":\"\",\"productKey\":\"kanky-story-gozen-sepatu-sneakers-casual-sport-sekolah-wanita-dewasa-172984